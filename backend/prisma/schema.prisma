// Prisma schema for Nabad backend

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Site {
  id               String   @id
  importJobId      String?
  importJob        ImportJob? @relation(fields: [importJobId], references: [id])
  settlementName   String
  district         String?
  region           String?
  ochaRegionPcode  String?
  ochaDistrictPcode String?
  operationalZone  String?
  catchment        String?
  classification   String?
  locationType     String?
  lat              Float?
  lon              Float?
  households       Int?
  arrivals14d      Int?
  arrivalsMale     Int?
  arrivalsFemale   Int?
  arrivalsChildren Int?
  departures14d    Int?
  mainCause        String?
  hazardCause      String?
  conflictCause    String?
  mainNeed         String?
  needs            Json?
  responses        Json?
  movementType     String?
  displacementCount String?
  journeyTime      String?
  originRegion     String?
  originDistrict   String?
  originLocation   String?
  dataCollectionWeek String?
  penta3           Float?
  gam              Float?
  safety           Float?
  raw              Json?
  updatedAt        DateTime @updatedAt
}

model IndicatorObservation {
  id          String      @id
  importJobId String?
  importJob   ImportJob?  @relation(fields: [importJobId], references: [id])
  source      String
  dataset     String
  indicator   String
  locationName String
  district    String?
  region      String?
  periodLabel String
  periodDate  DateTime?
  numerator   Float?
  denominator Float?
  value       Float
  notes       String?
  raw         Json?
  createdAt   DateTime    @default(now())
}

model CommunityAlert {
  id         String   @id
  siteName   String
  district   String?
  channel    String?
  category   String?
  severity   String?
  message    String
  reportedAt DateTime
}

model Form {
  id          String   @id
  title       String
  slug        String   @unique
  description String?
  headerImage String?
  fields      Json
  sections    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  responses   FormResponse[]
}

model FormResponse {
  id          String   @id
  formId      String
  form        Form     @relation(fields: [formId], references: [id])
  answers     Json
  submittedAt DateTime @default(now())
  sourceIp    String?
}

model ImportJob {
  id         String   @id
  filename   String
  status     String   // pending | failed | done
  message    String?
  tempPath   String?
  savedTemp  Boolean  @default(false)
  totalRows  Int?
  importedRows Int   @default(0)
  createdAt  DateTime @default(now())
  finishedAt DateTime?
  sites      Site[]
  observations IndicatorObservation[]
}

model User {
  id                 String  @id
  email              String  @unique
  name               String
  password           String
  role               String
  firstLogin         Boolean @default(true)
  mustChangePassword Boolean @default(false)
}
